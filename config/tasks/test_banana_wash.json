      "grasp_mode": "top",
      "approach_clearance_m": 0.13,
      "lift_height_m": 0.20,
      "timeout_s": 45,
      "success_criteria": {
        "min_lift_delta_m": 0.015
      }
    },
    {
      "id": "T2",
      "type": "carry_to",
      "destination_label": "sink",
      "destination_xy": [2.4, 0.9],
      "destination_usd_path": "/World/SinkCabinet/Basin",
      "carry_height_m": 0.30,
      "approach_clearance_m": 0.15,
      "tolerance_m": 0.22,
      "timeout_s": 75,
      "success_on_timeout": true
    },
    {
      "id": "T3",
      "type": "place_object",
      "destination_usd_path": "/World/SinkCabinet/Basin",
      "release_height_m": 0.08,
      "timeout_s": 10
    },
    {
      "id": "T4",

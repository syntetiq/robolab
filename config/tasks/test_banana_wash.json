{
  "episode_name": "test_banana_wash",
  "description": "Pick banana from plate, carry to sink, wait 3s (washing), pick back, return to plate",
  "simulation_duration_s": 320,

  "scene": {
    "fridge":      false,
    "dishwasher":  false,
    "sink":        true,
    "plate_fruit": true
  },

  "robot": {
    "start_pose": [0.0, 0.0],
    "model": "heavy",
    "gripper_length_m": 0.10
  },

  "global": {
    "drive_speed_ms": 0.45,
    "approach_clearance_m": 0.13,
    "torso_speed": 0.05,
    "on_task_failure": "continue"
  },

  "tasks": [
    {
      "id": "T1",
      "type": "pick_object",
      "object_usd_path": "/World/Banana1",

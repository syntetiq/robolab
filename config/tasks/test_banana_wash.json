      "lift_height_m": 0.20,
      "timeout_s": 45,
      "success_criteria": {
        "min_lift_delta_m": 0.015
      }
    },
    {
      "id": "T6",
      "type": "carry_to",
      "destination_label": "plate",
      "destination_xy": [1.0, 1.05],
      "destination_usd_path": "/World/Plate",
      "carry_height_m": 0.30,
      "approach_clearance_m": 0.13,
      "tolerance_m": 0.22,
      "timeout_s": 75,
      "success_on_timeout": true
    },
    {
      "id": "T7",
      "type": "place_object",
      "destination_usd_path": "/World/Plate",
      "release_height_m": 0.05,
      "timeout_s": 10,
      "success_criteria": {
        "object_usd_path": "/World/Banana1",
        "max_xy_from_target_m": 0.15
      }
    }

{
  "episode_name": "test_mug_to_sink",
  "description": "Pick mug from table, carry to sink, place in basin, pick it back, return to table",
  "simulation_duration_s": 200,

  "scene": {
    "fridge":      false,
    "dishwasher":  false,
    "sink":        true,
    "plate_fruit": false
  },

  "robot": {
    "start_pose": [0.0, 0.0],
    "model": "heavy",
    "gripper_length_m": 0.10
  },

  "global": {
    "drive_speed_ms": 0.4,
    "approach_clearance_m": 0.13,
    "torso_speed": 0.05,
    "on_task_failure": "abort"
  },

  "tasks": [
    {
      "id": "T1",
      "type": "pick_object",
      "object_usd_path": "/World/Mug",
      "object_label": "mug",
      "grasp_mode": "top",
      "approach_clearance_m": 0.13,
      "lift_height_m": 0.20,
      "timeout_s": 45,
      "success_criteria": {
        "min_lift_delta_m": 0.02
      }
    },
    {
      "id": "T2",
      "type": "carry_to",
      "destination_label": "sink",
      "destination_xy": [2.4, 0.9],
      "destination_usd_path": "/World/SinkCabinet/Basin",
      "carry_height_m": 0.30,
      "approach_clearance_m": 0.15,
      "tolerance_m": 0.18,
      "timeout_s": 45,
      "success_on_timeout": true
    },
    {
      "id": "T3",
      "type": "place_object",
      "destination_usd_path": "/World/SinkCabinet/Basin",
      "release_height_m": 0.10,
      "timeout_s": 10,
      "success_criteria": {
        "object_usd_path": "/World/Mug",
        "max_xy_from_target_m": 0.20
      }
    },
    {
      "id": "T4",
      "type": "wait",
      "duration_s": 1.0,
      "annotation": "mug placed in sink"
    },
    {
      "id": "T5",
      "type": "pick_object",
      "object_usd_path": "/World/Mug",
      "object_label": "mug (return)",
      "grasp_mode": "top",
      "approach_clearance_m": 0.15,
      "lift_height_m": 0.20,
      "timeout_s": 45,
      "success_criteria": {
        "min_lift_delta_m": 0.02
      }
    },
    {
      "id": "T6",
      "type": "carry_to",
      "destination_label": "table",
      "destination_xy": [1.0, 1.2],
      "destination_usd_path": "/World/Table",
      "carry_height_m": 0.30,
      "approach_clearance_m": 0.13,
      "tolerance_m": 0.18,
      "timeout_s": 45,
      "success_on_timeout": true
    },
    {
      "id": "T7",
      "type": "place_object",
      "destination_usd_path": "/World/Table",
      "release_height_m": 0.05,
      "timeout_s": 10,
      "success_criteria": {
        "object_usd_path": "/World/Mug",
        "max_xy_from_target_m": 0.20
      }
    }
  ]
}

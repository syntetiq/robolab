{
  "episode_name": "test_dishwasher_open_close",
  "description": "Drive to dishwasher, open door to 80 degrees, wait, then close",
  "simulation_duration_s": 90,

  "scene": {
    "fridge":      false,
    "dishwasher":  true,
    "sink":        false,
    "plate_fruit": false
  },

  "robot": {
    "start_pose": [0.0, 0.0],
    "model": "heavy",
    "gripper_length_m": 0.10
  },

  "global": {
    "drive_speed_ms": 0.3,
    "approach_clearance_m": 0.15,
    "torso_speed": 0.05,
    "on_task_failure": "abort"
  },

  "tasks": [
    {
      "id": "T1",
      "type": "navigate_to",
      "target_xy": [1.8, -1.0],
      "tolerance_m": 0.05,
      "timeout_s": 15
    },
    {
      "id": "T2",
      "type": "open_door",
      "target": "dishwasher",
      "handle_usd_path": "/World/Dishwasher/Door/Handle",
      "approach_clearance_m": 0.15,
      "target_angle_deg": 80,
      "pull_speed_ms": 0.05,
      "timeout_s": 25,
      "success_criteria": {
        "door_joint_path": "/World/Dishwasher/DoorHinge",
        "min_angle_deg": 60
      }
    },
    {
      "id": "T3",
      "type": "wait",
      "duration_s": 2.0,
      "annotation": "door open — verify racks visible"
    },
    {
      "id": "T4",
      "type": "close_door",
      "target": "dishwasher",
      "handle_usd_path": "/World/Dishwasher/Door/Handle",
      "push_speed_ms": 0.10,
      "timeout_s": 30,
      "success_criteria": {
        "door_joint_path": "/World/Dishwasher/DoorHinge",
        "max_angle_deg": 10
      }
    }
  ]
}

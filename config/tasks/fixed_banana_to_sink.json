{
  "episode_name": "fixed_banana_to_sink",
  "description": "Drive to banana on plate, pick up, carry to sink, place in basin, return to start",
  "kitchen_scene": "fixed",
  "simulation_duration_s": 300,

  "scene": {
    "fridge":      true,
    "dishwasher":  false,
    "sink":        true,
    "plate_fruit": true
  },

  "robot": {
    "start_pose": [0.0, 0.0, 90],
    "model": "heavy",
    "gripper_length_m": 0.10,
    "robot_profile": "config/robots/tiago_heavy.yaml"
  },

  "global": {
    "drive_speed_ms": 0.3,
    "approach_clearance_m": 0.13,
    "torso_speed": 0.05,
    "on_task_failure": "abort"
  },

  "safety": {
    "table_south_boundary_y": 2.75,
    "furniture_zones": [
      {"name": "fridge",       "cx": -1.35, "cy": 3.45, "hw": 0.50, "hd": 0.50},
      {"name": "sink_cabinet", "cx":  0.45, "cy": 3.60, "hw": 0.50, "hd": 0.40},
      {"name": "table",        "cx":  1.35, "cy": 3.55, "hw": 0.50, "hd": 0.50}
    ],
    "nav_margin": 0.35
  },

  "control": {
    "grasp_settle_steps": 120,
    "settle_steps": 240,
    "extend_arm_steps": 300,
    "rotate_timeout_steps": 1200,
    "drive_to_mug_timeout_steps": 1800,
    "settle_at_table_steps": 360,
    "approach_timeout_steps": 1800,
    "descend_timeout_steps": 3000,
    "close_gripper_step": 45,
    "close_gripper_timeout": 270,
    "verify_grasp_min_steps": 60,
    "lift_interpolation_steps": 600,
    "lift_verify_steps": 240,
    "lift_timeout_steps": 1500,
    "place_descent_steps": 600
  },

  "grasp": {
    "pre_grasp_pose": "pre_grasp_top",
    "j4_extended": -0.35,
    "j4_retracted": 0.30,
    "torso_approach": 0.35,
    "torso_settle": 0.15,
    "torso_hold": 0.35,
    "top_xy_tol": 0.01,
    "top_descend_clearance": 0.04,
    "top_descend_speed": 0.03,
    "top_verify_xy_tol": 0.05,
    "gripper_close_value": 0.015,
    "gripper_final_close_value": 0.010,
    "gripper_hold_threshold": 0.005
  },

  "navigation": {
    "rotate_tolerance_deg": 5.0,
    "rotate_speed_fast": 0.3,
    "rotate_speed_slow": 0.15,
    "rotate_speed_threshold_deg": 20.0,
    "drive_speed_cap": 0.12,
    "y_align_tolerance": 0.005,
    "y_align_speed": 0.06,
    "approach_speed": 0.02,
    "x_guard_extra": 0.20,
    "stuck_threshold": 0.002,
    "stuck_trigger_steps": 600,
    "stuck_phase_steps": 300,
    "stuck_lateral_factor": 0.3,
    "stuck_backward_factor": 0.4,
    "velocity_norm_scale": 2.0,
    "velocity_min_dist": 0.01
  },

  "placement": {
    "table_top_z": 0.80,
    "table_cx": 1.35,
    "table_cy": 3.45,
    "table_half_w": 0.40,
    "table_half_d": 0.40,
    "bounds_margin": 0.05,
    "abort_below_z_offset": -0.05,
    "release_z_offset": 0.02,
    "success_z_offset": 0.15
  },

  "physics": {
    "physics_dt": 0.008333333333333333,
    "rendering_dt": 0.016666666666666666,
    "log_every": 6,
    "console_every": 60,
    "render_every": 2
  },

  "tasks": [
    {
      "id": "T1_drive_to_banana",
      "type": "navigate_to",
      "target_xy": [1.55, 2.50],
      "tolerance_m": 0.25,
      "timeout_s": 50,
      "drive_speed_ms": 0.4,
      "annotation": "Drive south of banana (banana at X=1.55, Y=3.45 on plate; robot stops at Y=2.50)"
    },
    {
      "id": "T2_pick_banana",
      "type": "pick_object",
      "object_usd_path": "/World/Kitchen/Objects/Banana",
      "object_label": "banana",
      "grasp_mode": "top",
      "approach_arm_retracted": true,
      "lift_with_torso_only": false,
      "lift_interpolation_steps_override": 1200,
      "approach_clearance_m": 0.13,
      "lift_height_m": 0.20,
      "timeout_s": 90,
      "success_criteria": {
        "min_lift_delta_m": 0.02
      },
      "annotation": "Grasp banana from top, lift 20cm"
    },
    {
      "id": "T3_carry_to_sink",
      "type": "carry_to",
      "object_usd_path": "/World/Kitchen/Objects/Banana",
      "destination_label": "south_of_sink",
      "destination_xy": [0.45, 2.80],
      "relative": false,
      "carry_height_m": 0.20,
      "approach_clearance_m": 0.13,
      "tolerance_m": 0.20,
      "timeout_s": 40,
      "drive_speed_ms": 0.15,
      "final_heading_deg": 180,
      "annotation": "Carry banana west to south of sink, then rotate to face west (arm extends north over sink)"
    },
    {
      "id": "T4_place_in_sink",
      "type": "place_object",
      "destination_usd_path": "/World/Kitchen/Furniture/SinkCabinet",
      "release_height_m": 0.05,
      "timeout_s": 10,
      "placement_top_z": 0.90,
      "placement_cx": 0.45,
      "placement_cy": 3.10,
      "placement_half_w": 0.50,
      "placement_half_d": 0.50,
      "placement_margin": 0.20,
      "placement_abort_z_offset": -0.30,
      "placement_release_z_offset": 0.10,
      "placement_success_z_offset": 0.30,
      "success_criteria": {
        "object_usd_path": "/World/Kitchen/Objects/Banana",
        "max_xy_from_target_m": 0.80
      },
      "annotation": "Place banana in/near sink (top Z=0.90, wide bounds for drop placement)"
    },
    {
      "id": "T5_return_to_start",
      "type": "navigate_to",
      "target_xy": [0.0, 0.0],
      "tolerance_m": 1.50,
      "timeout_s": 60,
      "drive_speed_ms": 0.4,
      "annotation": "Return towards starting position (loose tolerance, best-effort)"
    }
  ]
}

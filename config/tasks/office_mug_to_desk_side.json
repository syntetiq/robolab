{
  "episode_name": "office_mug_to_desk_side",
  "description": "Office scene: navigate to desk_main, pick up mug, carry to desk_side, place down, return to start",
  "kitchen_scene": "office_fixed",
  "simulation_duration_s": 300,

  "scene": {
    "desk_main":  true,
    "desk_side":  true,
    "desk_back":  true,
    "cabinet":    true,
    "chair":      true
  },

  "robot": {
    "start_pose": [0.0, 0.0, 90],
    "model": "heavy",
    "gripper_length_m": 0.10,
    "robot_profile": "config/robots/tiago_heavy.yaml"
  },

  "global": {
    "drive_speed_ms": 0.3,
    "approach_clearance_m": 0.13,
    "torso_speed": 0.05,
    "on_task_failure": "abort"
  },

  "safety": {
    "table_south_boundary_y": 1.20,
    "furniture_zones": [
      {"name": "desk_main",   "cx":  0.0, "cy": 2.00, "hw": 0.80, "hd": 0.40},
      {"name": "desk_side",   "cx":  3.0, "cy": 2.00, "hw": 0.70, "hd": 0.35},
      {"name": "desk_back",   "cx": -3.0, "cy": 3.00, "hw": 0.80, "hd": 0.40},
      {"name": "cabinet",     "cx": -4.0, "cy": 3.60, "hw": 0.45, "hd": 0.25},
      {"name": "chair",       "cx":  0.0, "cy": 0.80, "hw": 0.30, "hd": 0.30}
    ],
    "nav_margin": 0.35
  },

  "control": {
    "grasp_settle_steps": 360,
    "settle_steps": 240,
    "extend_arm_steps": 600,
    "rotate_timeout_steps": 1200,
    "drive_to_mug_timeout_steps": 1800,
    "settle_at_table_steps": 240,
    "approach_timeout_steps": 1200,
    "descend_timeout_steps": 1500,
    "close_gripper_step": 45,
    "close_gripper_timeout": 270,
    "verify_grasp_min_steps": 60,
    "lift_interpolation_steps": 600,
    "lift_verify_steps": 240,
    "lift_timeout_steps": 1200,
    "place_descent_steps": 600
  },

  "grasp": {
    "pre_grasp_pose": "pre_grasp_top",
    "j4_extended": -0.35,
    "j4_retracted": 0.30,
    "torso_approach": 0.35,
    "torso_settle": 0.15,
    "torso_hold": 0.35,
    "top_xy_tol": 0.02,
    "top_descend_clearance": 0.015,
    "top_verify_xy_tol": 0.05,
    "gripper_close_value": 0.018,
    "gripper_hold_threshold": 0.01
  },

  "navigation": {
    "rotate_tolerance_deg": 5.0,
    "rotate_speed_fast": 0.3,
    "rotate_speed_slow": 0.15,
    "rotate_speed_threshold_deg": 20.0,
    "drive_speed_cap": 0.12,
    "y_align_tolerance": 0.005,
    "y_align_speed": 0.06,
    "approach_speed": 0.05,
    "x_guard_extra": 0.20,
    "stuck_threshold": 0.002,
    "stuck_trigger_steps": 600,
    "stuck_phase_steps": 300,
    "stuck_lateral_factor": 0.3,
    "stuck_backward_factor": 0.4,
    "velocity_norm_scale": 2.0,
    "velocity_min_dist": 0.01
  },

  "placement": {
    "table_top_z": 0.75,
    "table_cx": 3.0,
    "table_cy": 2.0,
    "table_half_w": 0.70,
    "table_half_d": 0.35,
    "bounds_margin": 0.05,
    "abort_below_z_offset": -0.05,
    "release_z_offset": 0.02,
    "success_z_offset": 0.15
  },

  "physics": {
    "physics_dt": 0.008333333333333333,
    "rendering_dt": 0.016666666666666666,
    "log_every": 6,
    "console_every": 60,
    "render_every": 2
  },

  "tasks": [
    {
      "id": "T1_drive_to_desk_main",
      "type": "navigate_to",
      "target_xy": [0.30, 1.20],
      "tolerance_m": 0.25,
      "timeout_s": 50,
      "drive_speed_ms": 0.4,
      "annotation": "Drive south of desk_main to approach the mug (mug at X=0.30, Y=2.00; robot stops at Y=1.20, ~0.80m behind mug)"
    },
    {
      "id": "T2_pick_mug",
      "type": "pick_object",
      "object_usd_path": "/World/Office/Objects/Mug",
      "object_label": "mug",
      "grasp_mode": "top",
      "approach_clearance_m": 0.13,
      "lift_height_m": 0.20,
      "timeout_s": 90,
      "success_criteria": {
        "min_lift_delta_m": 0.02
      },
      "annotation": "Top-grasp the mug from desk_main and lift 20 cm"
    },
    {
      "id": "T3_carry_to_desk_side",
      "type": "carry_to",
      "destination_label": "desk_side",
      "destination_xy": [2.30, 1.20],
      "relative": false,
      "carry_height_m": 0.20,
      "approach_clearance_m": 0.13,
      "tolerance_m": 0.20,
      "timeout_s": 60,
      "annotation": "Carry mug east to a position south of desk_side (desk_side centred at X=3.0, Y=2.0)"
    },
    {
      "id": "T4_place_mug",
      "type": "place_object",
      "destination_usd_path": "/World/Office/Furniture/desk_side",
      "release_height_m": 0.05,
      "timeout_s": 20,
      "success_criteria": {
        "object_usd_path": "/World/Office/Objects/Mug",
        "max_xy_from_target_m": 0.40
      },
      "annotation": "Place mug down on desk_side"
    },
    {
      "id": "T5_return_to_start",
      "type": "navigate_to",
      "target_xy": [0.0, 0.0],
      "tolerance_m": 1.50,
      "timeout_s": 60,
      "drive_speed_ms": 0.4,
      "annotation": "Return towards starting position (loose tolerance, best-effort)"
    }
  ]
}
